# emalro backend — environment template
# Copy this file to `.env` and fill in real values. Never commit `.env`.

# --- Required ---
# Local dev: postgresql+asyncpg://emalro:emalro@localhost:5432/emalro
# Production: postgresql+asyncpg://postgres.<ref>:<pwd>@pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql+asyncpg://emalro:emalro@localhost:5432/emalro

SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_KEY=<set-in-render-or-local>

# 32+ characters of high-entropy random data. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=<random-32+-chars-set-once-and-kept-secret>

# --- Optional (defaults shown) ---
JWT_EXPIRATION_HOURS=8
ALLOWED_ORIGINS=http://localhost:4321
ENV=dev
PORT=8000
LOGIN_RATE_LIMIT=5/minute
CONTACT_RATE_LIMIT=5/hour
IMAGE_MAX_BYTES=5242880

# --- Optional: Cloudflare cache purge (no-op when empty) ---
# CLOUDFLARE_ZONE_ID=
# CLOUDFLARE_API_TOKEN=
