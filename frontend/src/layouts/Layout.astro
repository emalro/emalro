---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/sections/Footer.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Emanuel Romero — Portfolio",
  description = "Data Analyst portfolio. Experience, education, projects, and courses.",
} = Astro.props;

// The cold-start ping hits `/api/v1/health` on the backend. We
// strip the optional `/api/v1` suffix from `PUBLIC_API_URL` so the
// final URL is always `${base}/api/v1/health` regardless of whether
// the operator set `PUBLIC_API_URL=http://localhost:8000` (canonical)
// or `PUBLIC_API_URL=http://localhost:8000/api/v1` (local-dev
// convenience). Same normalization as `src/lib/api.ts`.
const rawApiUrl = (import.meta.env.PUBLIC_API_URL as string | undefined) ?? "";
const apiBase = rawApiUrl
  .replace(/\/+$/, "")
  .replace(/\/api\/v1$/, "");
---

<!doctype html>
<html lang="es" data-theme="dark" data-lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=JetBrains+Mono:wght@400;600&display=swap"
    />
    <title>{title}</title>
    <script is:inline>
      // Pre-paint theme + language resolution. Inlined for FOUC mitigation.
      // Mirrors src/scripts/head-bootstrap.ts; kept in sync intentionally.
      (function () {
        try {
          var t = localStorage.getItem("theme");
          var l = localStorage.getItem("lang");
          var theme = t === "light" || t === "dark" ? t : "dark";
          var lang = l === "en" || l === "es" ? l : "es";
          document.documentElement.setAttribute("data-theme", theme);
          document.documentElement.setAttribute("data-lang", lang);
          document.documentElement.setAttribute("lang", lang);
        } catch (e) {
          document.documentElement.setAttribute("data-theme", "dark");
          document.documentElement.setAttribute("data-lang", "es");
        }
      })();
    </script>
  </head>
  <body class="min-h-dvh bg-bg-base text-ink-primary antialiased">
    <Navbar />
    <main class="mx-auto max-w-6xl px-6 pb-24 pt-12 md:px-8">
      <slot />
    </main>
    <Footer />
    <script>
      import "../scripts/i18n.ts";
      import "../scripts/theme.ts";
      import "../scripts/sort.ts";
      import "../scripts/lenis.ts";
      import "../scripts/typed-role.ts";
    </script>
    {/*
      Cold-start ping (per `cold-start-ping` REQ-02..05). Inline
      script (no `client:` directive, no JS bundle) that fires a
      keepalive GET to /api/v1/health on first paint. The `keepalive`
      flag survives tab close; the 64 KB cap is irrelevant (the
      health response is ~30 bytes). Fire-and-forget: no retries, no
      UI, no await. URL parse failure on empty PUBLIC_API_URL is
      silently swallowed.

      The Astro `define:vars` directive is the canonical way to
      inject a build-time value into an `is:inline` script (Astro
      does NOT process `import.meta.env` inside raw inline scripts).
    */}
    <script is:inline define:vars={{ apiBase }}>
      (function () {
        try {
          var url = (apiBase || "") + "/api/v1/health";
          if (typeof fetch === "function") {
            fetch(url, { keepalive: true, method: "GET" }).catch(
              function () {},
            );
          }
        } catch (_) {
          /* cold-start ping is best-effort; never block paint */
        }
      })();
    </script>
  </body>
</html>
