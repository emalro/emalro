---
/**
 * Public /contact page (per `contact-form` REQ-contact-form-01).
 *
 * The page is a thin Astro shell: SEO meta + localized page
 * heading + the `<ContactForm client:load />` Preact island.
 * The form is hydrated immediately (`client:load`) because the
 * contact form is the only thing on the page; deferring
 * hydration would be wasted complexity.
 *
 * Build-time vs runtime: the form is a runtime concern (it
 * requires user input + a POST), so this page does NOT call
 * any backend at build time. The only data sources are the
 * localized labels embedded in the Preact island (in
 * `components/contact/i18n.ts`).
 */
import Layout from "../layouts/Layout.astro";
import { ContactForm } from "../components/contact/ContactForm";
import { contactLabels, resolveLabel } from "../components/contact/i18n";

const lang = (Astro.url.searchParams.get("lang") === "en" ? "en" : "es") as
  | "es"
  | "en";

const heading = resolveLabel(contactLabels.page.heading, lang);
const intro = resolveLabel(contactLabels.page.intro, lang);
const backLink = resolveLabel(contactLabels.page.backLink, lang);
const eyebrow = resolveLabel(contactLabels.page.eyebrow, lang);

const title =
  lang === "en"
    ? "Contact — Emanuel Romero"
    : "Contacto — Emanuel Romero";
const description =
  lang === "en"
    ? "Get in touch with Emanuel Romero — data analyst portfolio."
    : "Contactate con Emanuel Romero — portfolio de análisis de datos.";
---

<Layout title={title} description={description}>
  <header class="grid gap-3 py-12 md:py-16">
    <p class="font-mono text-xs uppercase tracking-widest text-accent">
      {eyebrow}
    </p>
    <h1 class="font-mono text-3xl font-bold md:text-5xl">{heading}</h1>
    <p class="max-w-2xl text-base text-ink-secondary md:text-lg">
      {intro}
    </p>
  </header>

  <section class="grid gap-6 pb-16 md:pb-24">
    <ContactForm client:load initialLang={lang} />
  </section>

  <p class="pb-12 text-sm text-ink-tertiary md:pb-16">
    <a
      href="/"
      class="font-mono text-accent hover:underline focus:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-bg-base"
    >
      {backLink}
    </a>
  </p>
</Layout>
