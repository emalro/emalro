---
/**
 * Footer per spec portfolio-footer.
 *
 * Two-region layout: copyright on the left, social icons on the right.
 * The year is computed at runtime (PR #1 already did this) so the
 * copyright stays current without a rebuild. Social URLs come from
 * src/data/social.json — the four required networks are rendered in
 * the locked order (LinkedIn, Repo, Kaggle, Tableau Public) and any
 * empty URL is hidden.
 *
 * The `repo` platform is provider-agnostic (was `github` in MVP):
 * the operator can swap the URL in `social.json` to point at
 * GitLab, Bitbucket, Codeberg, etc. without renaming the field.
 *
 * Platform names are not localized (they are proper nouns in both
 * ES and EN), so this component does not consume the i18n contract
 * for the labels — the aria-label and visible label are stable.
 */
import social from "../../data/social.json";
import SocialIcon from "../ui/SocialIcon.astro";

const year = new Date().getFullYear();

const networks = [
  { platform: "linkedin" as const, key: "linkedin", label: "LinkedIn" },
  { platform: "repo" as const, key: "repo", label: "Repo" },
  { platform: "kaggle" as const, key: "kaggle", label: "Kaggle" },
  { platform: "tableau" as const, key: "tableau_public", label: "Tableau Public" },
];
---

<footer class="border-t border-border">
  <div
    class="mx-auto flex max-w-6xl flex-col gap-4 px-6 py-6 text-xs text-ink-tertiary md:flex-row md:items-center md:justify-between md:px-8"
  >
    <p class="font-mono">
      © {year} <span class="text-ink-secondary">Emanuel Romero</span>
    </p>
    <div class="flex flex-wrap items-center gap-1" role="list" aria-label="Social links">
      {networks.map((n) => {
        const url = social[n.key as keyof typeof social];
        if (!url) return null;
        return (
          <div role="listitem">
            <SocialIcon platform={n.platform} url={url} label={n.label} />
          </div>
        );
      })}
    </div>
  </div>
</footer>
