---
import ThemeToggle from "./ThemeToggle.astro";
import LanguageSelector from "./LanguageSelector.astro";

/**
 * Top-level nav links (per `contact-form` REQ-contact-form-01 +
 * the blog-section PR that added the Blog teaser on the homepage).
 *
 * The first five entries are in-page anchors to the homepage
 * sections; the last two (`blog`, `contact`) are real routes.
 * `data-anchor-id` is set on every link so the existing
 * `data-mobile-nav` script can find anchors and dismiss the
 * mobile menu on click. Routes (non-`#` links) don't carry the
 * `data-anchor-id` attribute because the smooth-scroll code
 * only fires on hash-prefixed hrefs (`#xxx` or `/#xxx`).
 */
const links = [
  { id: "hero", label: { es: "Inicio", en: "Home" }, href: "/#hero" },
  { id: "experience", label: { es: "Experiencia", en: "Experience" }, href: "/#experience" },
  { id: "education", label: { es: "Educación", en: "Education" }, href: "/#education" },
  { id: "projects", label: { es: "Proyectos", en: "Projects" }, href: "/#projects" },
  { id: "courses", label: { es: "Cursos", en: "Courses" }, href: "/#courses" },
  { id: "blog", label: { es: "Blog", en: "Blog" }, href: "/blog" },
  { id: "contact", label: { es: "Contacto", en: "Contact" }, href: "/contact" },
] as const;
---

<header
  class="sticky top-0 z-40 h-16 border-b border-border bg-bg-base/85 backdrop-blur"
>
  <div class="mx-auto flex h-full max-w-6xl items-center gap-3 px-4 md:px-8">
    <a
      href="#hero"
      class="font-mono text-sm font-bold tracking-tight text-accent"
      aria-label="Emanuel Romero"
    >
      emalro
    </a>
    <nav class="ml-4 hidden flex-1 items-center gap-1 md:flex">
      {
        links.map((link) => {
          const isAnchor = link.href.includes("#");
          return (
            <a
              href={link.href}
              class="rounded-md px-3 py-2 text-sm text-ink-secondary hover:bg-bg-surface hover:text-ink-primary"
              data-i18n={JSON.stringify(link.label)}
              data-anchor-id={isAnchor ? link.id : undefined}
            >
              {link.label.es}
            </a>
          );
        })
      }
    </nav>
    <div class="ml-auto flex items-center gap-2">
      <button
        type="button"
        class="inline-flex h-10 w-10 items-center justify-center rounded-md border border-border bg-bg-surface font-mono text-lg leading-none text-accent transition-colors hover:bg-bg-elevated md:hidden"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-nav"
        data-mobile-nav-toggle
      >
        ≡
      </button>
      <LanguageSelector />
      <ThemeToggle />
    </div>
  </div>
  <div
    id="mobile-nav"
    class="absolute inset-x-0 top-full hidden border-b border-border bg-bg-surface shadow-lg md:hidden"
    data-mobile-nav
  >
    <nav
      class="mx-auto flex max-w-6xl flex-col px-4 py-2"
      aria-label="Mobile navigation"
    >
      {
        links.map((link) => {
          const isAnchor = link.href.includes("#");
          return (
            <a
              href={link.href}
              class="flex items-center border-l-2 border-transparent py-3 pl-4 font-mono text-sm text-ink-secondary transition-colors hover:border-accent hover:bg-bg-elevated hover:text-ink-primary"
              data-anchor-id={isAnchor ? link.id : undefined}
            >
              <span class="mr-2 text-accent" aria-hidden="true">&gt;</span>
              <span data-i18n={JSON.stringify(link.label)}>{link.label.es}</span>
            </a>
          );
        })
      }
    </nav>
  </div>
</header>

<script>
  const toggle = document.querySelector<HTMLButtonElement>(
    "[data-mobile-nav-toggle]",
  );
  const menu = document.querySelector<HTMLElement>("[data-mobile-nav]");

  if (toggle && menu) {
    const setOpen = (open: boolean) => {
      menu.classList.toggle("hidden", !open);
      toggle.setAttribute("aria-expanded", String(open));
      toggle.setAttribute("aria-label", open ? "Close menu" : "Open menu");
    };
    toggle.addEventListener("click", () => {
      setOpen(toggle.getAttribute("aria-expanded") !== "true");
    });
    menu
      .querySelectorAll<HTMLAnchorElement>("a[href*='#']")
      .forEach((link) => link.addEventListener("click", () => setOpen(false)));
    document.addEventListener("keydown", (event) => {
      if (
        event.key === "Escape" &&
        toggle.getAttribute("aria-expanded") === "true"
      ) {
        setOpen(false);
        toggle.focus();
      }
    });
  }
</script>