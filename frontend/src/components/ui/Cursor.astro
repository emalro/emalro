---
// Terminal-style cursor for the Hero role line.
// Width-morph animation: alternates between 0.6ch (insert) and
// 0.1ch (overwrite) every 0.5s with a smooth ease, simulating
// a real terminal cursor toggling insert mode.
---
<span data-typed-cursor class="ml-0.5 inline-block h-[1em] w-[0.6ch] -translate-y-[0.1em] bg-accent" aria-hidden="true"></span>
<style>
  [data-typed-cursor] { animation: cursor-morph 1s ease-in-out infinite; }
  @keyframes cursor-morph {
    0%, 100% { width: 0.6ch; opacity: 1; }
    50%      { width: 0.1ch; opacity: 0.6; }
  }
</style>
