---
/**
 * Social icon link used in the Footer.
 *
 * Renders a compact icon + platform name in JetBrains Mono with the
 * ink-secondary tone, switching to the accent amber on hover. Each
 * link opens in a new tab with rel=noopener noreferrer per spec
 * REQ-footer-02. Empty URLs are skipped by the parent so this
 * component never sees a missing href.
 *
 * Icons are simple monochrome SVG marks — one recognizable glyph per
 * platform — to stay within the data terminal aesthetic (muted, mono,
 * small) without depending on a heavy icon font.
 */
interface Props {
  platform: "linkedin" | "github" | "kaggle" | "tableau";
  url: string;
  label: string;
}
const { platform, url, label } = Astro.props;

const ICONS: Record<Props["platform"], string> = {
  // LinkedIn: stylized "in" within a rounded square.
  linkedin:
    '<rect x="3" y="3" width="18" height="18" rx="2" fill="currentColor"/><rect x="6" y="9" width="2" height="9" fill="var(--bg-surface)"/><circle cx="7" cy="6.5" r="1.2" fill="var(--bg-surface)"/><path d="M11 18V9h2v1.2c.6-.8 1.4-1.4 2.6-1.4 2 0 3.4 1.2 3.4 3.6V18h-2v-5c0-1.2-.5-2-1.7-2-1.1 0-1.8.7-2.3 1.6V18h-2z" fill="var(--bg-surface)"/>',
  // GitHub: simple octocat silhouette.
  github:
    '<path d="M12 2a10 10 0 0 0-3.16 19.49c.5.09.68-.22.68-.48v-1.7c-2.78.6-3.37-1.34-3.37-1.34-.46-1.16-1.12-1.47-1.12-1.47-.91-.62.07-.61.07-.61 1.01.07 1.54 1.04 1.54 1.04.9 1.53 2.35 1.09 2.92.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.95 0-1.09.39-1.99 1.03-2.69-.1-.25-.45-1.27.1-2.65 0 0 .84-.27 2.76 1.03A9.5 9.5 0 0 1 12 6.8c.86 0 1.72.11 2.52.33 1.92-1.3 2.76-1.03 2.76-1.03.55 1.38.2 2.4.1 2.65.64.7 1.03 1.6 1.03 2.69 0 3.85-2.34 4.7-4.57 4.95.36.31.68.92.68 1.85v2.74c0 .27.18.58.69.48A10 10 0 0 0 12 2z" fill="currentColor"/>',
  // Kaggle: stylized "K" inside a square.
  kaggle:
    '<rect x="3" y="3" width="18" height="18" rx="2" fill="currentColor"/><path d="M7 6.5l5 5.5-5 5.5h2.6l3.7-4.1 3.7 4.1H19l-5-5.5 5-5.5h-2.6l-3.7 4.1L9.6 6.5z" fill="var(--bg-surface)"/>',
  // Tableau Public: three ascending bars.
  tableau:
    '<rect x="3" y="3" width="18" height="18" rx="2" fill="currentColor"/><rect x="7" y="11" width="3" height="6" fill="var(--bg-surface)"/><rect x="11" y="8" width="3" height="9" fill="var(--bg-surface)"/><rect x="15" y="5" width="3" height="12" fill="var(--bg-surface)"/>',
};
---

<a
  href={url}
  target="_blank"
  rel="noopener noreferrer"
  class="group inline-flex min-h-[44px] min-w-[44px] items-center justify-center gap-2 rounded-md px-2 py-1.5 text-ink-secondary transition-colors hover:bg-bg-surface hover:text-accent focus:outline-none focus-visible:ring-2 focus-visible:ring-accent"
  aria-label={label}
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    width="18"
    height="18"
    aria-hidden="true"
    set:html={ICONS[platform]}
  />
  <span class="hidden font-mono text-xs sm:inline">{label}</span>
</a>
